# Streamlit Cloud用シークレット設定例。
# 実際の値は Streamlit Cloud の "Settings → Secrets" にコピペで設定する。
# このファイル（.example付き）はGitHubに上げてOK。
# 本物の secrets.toml は絶対にコミットしない（.gitignore済み）。

# 公開Webデプロイ時は1にする。決算書PDF読取機能を非表示にし、anthropic API依存を切る。
WEB_MODE = "1"

# 全員共通のログインパスワード。所内で安全な経路（社内Slackなど）で共有。
APP_PASSWORD = "ここに任意のパスワード"

# 決算書PDF読取を使う場合のみ設定（WEB_MODE=1なら不要）。
# ANTHROPIC_API_KEY = "sk-ant-..."
